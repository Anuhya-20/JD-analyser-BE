# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
MANIFEST

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ── Environment Variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Database ──────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Alembic ───────────────────────────────────────────────────────────────────
