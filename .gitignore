*.pt
*.pth
*.bin
*.onnx
*.h5
/models/
.cache/
huggingface/
sentence_transformers_cache/

# ── Uploaded / Processed Files ────────────────────────────────────────────────
uploads/
temp/
tmp/
*.pdf
*.docx
*.doc

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
loguru_logs/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Mypy / Type Checkers ──────────────────────────────────────────────────────
