# Application
APP_NAME="JD Analyser API"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY="your-super-secret-key-change-in-production"

# Database
DATABASE_URL="postgresql+asyncpg://postgres:team12@localhost:5432/jd_analyser"
DATABASE_SYNC_URL="postgresql://postgres:team12@localhost:5432/jd_analyser"

# AI Provider: deepseek | openai | google
AI_PROVIDER="deepseek"

# DeepSeek (recommended — OpenAI-compatible, no extra package needed)
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"
DEEPSEEK_MODEL="deepseek-chat"
# DEEPSEEK_MODEL="deepseek-reasoner"   # use R1 for deeper analysis
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# OpenAI (alternative)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"

# Google Gemini (alternative)
GOOGLE_API_KEY="..."
GOOGLE_MODEL="gemini-2.5-pro"

# Embeddings (local model)
EMBEDDING_MODEL="BAAI/bge-base-en-v1.5"
EMBEDDING_DEVICE="cpu"

# Storage
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=50

# Processing
BATCH_SIZE=10
MAX_RESUME_PROCESSING_WORKERS=3
